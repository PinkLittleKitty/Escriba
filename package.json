{
  "name": "cuaderno-digital",
  "version": "1.0.0",
  "description": "Digital notebook application with cross-device sync",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron:start": "electron .",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.santiago.escriba",
    "productName": "Escriba",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "engines": {
    "node": ">=16.0.0"
  }
}