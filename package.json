{
  "name": "cuaderno-digital",
  "version": "1.0.0",
  "author": "Santiago",
  "description": "Digital notebook application with cross-device sync",
  "main": "electron.js",
  "scripts": {
    "electron:start": "electron .",
    "electron:build": "electron-builder --publish never",
    "mobile:prepare": "node scripts/prepare-mobile.js",
    "mobile:sync": "npm run mobile:prepare && npx cap sync android",
    "mobile:build": "npm run mobile:sync && cd android && ./gradlew assembleDebug"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^8.3.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.santiago.escriba",
    "productName": "Escriba",
    "icon": "icon.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  },
  "engines": {
    "node": ">=16.0.0"
  }
}